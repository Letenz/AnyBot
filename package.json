{
  "name": "anybot",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:release": "tsc && node ./scripts/copy-release-assets.mjs",
    "package:portable": "node ./scripts/package-portable.mjs",
    "package:desktop": "npm run build:release && node ./scripts/build-electron.mjs",
    "electron:dev": "npm run build:release && electron .",
    "electron:build": "npm run build:release && node ./scripts/build-electron.mjs",
    "electron:build:mac": "npm run build:release && node ./scripts/build-electron.mjs --mac",
    "electron:build:win": "npm run build:release && node ./scripts/build-electron.mjs --win",
    "start": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "bot:start": "node ./scripts/bot.mjs start",
    "bot:stop": "node ./scripts/bot.mjs stop",
    "bot:status": "node ./scripts/bot.mjs status"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@openai/codex-sdk": "^0.130.0",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "undici": "^7.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.3.1",
    "@types/ws": "^8.18.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "build": {
    "appId": "com.anybot.desktop",
    "productName": "AnyBot",
    "publish": [
      {
        "provider": "github",
        "owner": "1935417243",
        "repo": "AnyBot"
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json",
      "package-lock.json",
      "!src/**",
      "!scripts/**",
      "!installer/**",
      "!assets/**",
      "!release-assets/**",
      "!.packaging/**",
      "!.run/**",
      "!.data/**"
    ],
    "asar": false,
    "afterPack": "./electron/afterPack.cjs",
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "AnyBot",
      "uninstallDisplayName": "AnyBot"
    }
  }
}
