# ── Provider ──────────────────────────────────────────
# 可选: codex, gemini-cli, cursor-cli, qoder-cli, claude-code
# 可在 Web UI 中随时切换，无需重启
PROVIDER=codex

# ── Codex CLI ────────────────────────────────────────
CODEX_BIN=codex
CODEX_MODEL=
CODEX_SANDBOX=read-only
CODEX_SYSTEM_PROMPT=
# 工作目录，留空则使用当前目录
CODEX_WORKDIR=

# ── Gemini CLI ───────────────────────────────────────
GEMINI_CLI_BIN=gemini
GEMINI_CLI_MODEL=
# 可选: yolo（自动批准）, auto-edit, confirm
GEMINI_CLI_APPROVAL_MODE=yolo

# ── Cursor CLI ────────────────────────────────────────
CURSOR_CLI_BIN=agent
# 工作区路径（可选，默认用 CODEX_WORKDIR）
CURSOR_CLI_WORKSPACE=
# API Key（可选，也可用已登录状态）
CURSOR_API_KEY=

# ── Qoder CLI ────────────────────────────────────────
QODER_CLI_BIN=qodercli
# 最大 Agent 循环轮数（0 为不限制）
QODER_CLI_MAX_TURNS=

# ── Claude Agent SDK ─────────────────────────────────
# 默认使用本机已登录的 Claude Code CLI
CLAUDE_CODE_BIN=claude
# 可选：只在你想改用 API Key 认证时启用
# ANTHROPIC_API_KEY=
CLAUDE_AGENT_MODEL=
# 可选: default, acceptEdits, bypassPermissions, plan, dontAsk, auto
# 留空则按 CODEX_SANDBOX 自动映射
CLAUDE_AGENT_PERMISSION_MODE=
# 最大 Agent 循环轮数（留空为 SDK 默认）
CLAUDE_AGENT_MAX_TURNS=

# ── Web ──────────────────────────────────────────────
WEB_PORT=19981

# ── 日志 ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_INCLUDE_CONTENT=false
LOG_INCLUDE_PROMPT=false

# ── 代理 ─────────────────────────────────────────────
# 代理可在 Web UI 中配置，也可通过以下环境变量设置初始值
# 支持 HTTP 和 SOCKS5 代理
# PROXY_URL=http://127.0.0.1:7890
# PROXY_URL=socks5://127.0.0.1:7891
